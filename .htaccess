# === security hardening start ===
# セキュリティヘッダー
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

<FilesMatch "(?i)^dockerfile$">
  Require all denied
</FilesMatch>
<FilesMatch "(?i)^docker-compose\.ya?ml$">
  Require all denied
</FilesMatch>
<FilesMatch "\.(env|ya?ml|ini|log|sql|bak|tar|gz|zip)$">
  Require all denied
</FilesMatch>
<FilesMatch "^(?:\.gitignore|\.env|\.htpasswd)$">
  Require all denied
</FilesMatch>
<FilesMatch "^test-env\.php$">
  Require all denied
</FilesMatch>
<FilesMatch "^dbtest\.php$">
  Require all denied
</FilesMatch>
<FilesMatch "^(test-|debug-|dev-).*\.php$">
  Require all denied
</FilesMatch>
RedirectMatch 404 /(?:\.git|\.svn|\.hg)(?:/|$)
# === security hardening end ===


# Apache Cache Control Settings

# シンプルなキャッシュ設定
<IfModule mod_headers.c>
    # admin ディレクトリはキャッシュ無効化
    <If "%{REQUEST_URI} =~ m#^/admin/#">
        Header set Cache-Control "no-cache, no-store, must-revalidate, private"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </If>
    # ルート直下のAPI エンドポイントはキャッシュ無効化（admin以外）
    <ElseIf "%{REQUEST_URI} =~ m#^/(gdpr-consent|cache-test|cdn-test)\.php$#">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </ElseIf>
    <Else>
        Header set Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
    </Else>
</IfModule>
<IfModule mod_expires.c>
    ExpiresActive On
    # admin ディレクトリとAPIエンドポイントは除外
    <If "%{REQUEST_URI} !~ m#^/admin/# && %{REQUEST_URI} !~ m#^/(gdpr-consent|cache-test|cdn-test)\.php$#">
        ExpiresDefault "access plus 30 days"
    </If>
</IfModule>


RewriteEngine On

# 詳細ページのURL書き換え
RewriteRule ^detail/([a-zA-Z0-9\-]+)/?$ /detail/index.php?slug=$1 [QSA,L]

# 画像ファイルへの直接アクセスを許可
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule \.(png|jpg|jpeg|gif|webp)$ - [L]

# 存在するファイルやディレクトリへの直接アクセスを許可
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# エラーページ（404）
ErrorDocument 404 /404.php
