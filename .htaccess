# === security hardening start ===
# セキュリティヘッダー
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

<FilesMatch "(?i)^dockerfile$">
  Require all denied
</FilesMatch>
<FilesMatch "(?i)^docker-compose\.ya?ml$">
  Require all denied
</FilesMatch>
<FilesMatch "\.(env|ya?ml|ini|log|sql|bak|tar|gz|zip)$">
  Require all denied
</FilesMatch>
<FilesMatch "^(?:\.gitignore|\.env|\.htpasswd)$">
  Require all denied
</FilesMatch>
<FilesMatch "^test-env\.php$">
  Require all denied
</FilesMatch>
<FilesMatch "^dbtest\.php$">
  Require all denied
</FilesMatch>
<FilesMatch "^(test-|debug-|dev-).*\.php$">
  Require all denied
</FilesMatch>
RedirectMatch 404 /(?:\.git|\.svn|\.hg)(?:/|$)
# === security hardening end ===



RewriteEngine On

# 管理画面とAPIは除外（最初に処理）
RewriteRule ^(admin|api|uploads)/ - [L]

# 存在する画像ファイルへの直接アクセスは許可
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule \.(png|jpg|jpeg|gif|webp)$ - [L]

# 存在するファイルやディレクトリへの直接アクセスを許可
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# カテゴリページ: /category-slug/ → /category.php?slug=category-slug
RewriteRule ^([a-z0-9\-]+)/?$ category.php?slug=$1 [L,QSA]

# 素材詳細ページ: /category-slug/material-slug/ → /detail/index.php?category_slug=category-slug&slug=material-slug
RewriteRule ^([a-z0-9\-]+)/([a-z0-9\-]+)/?$ detail/index.php?category_slug=$1&slug=$2 [L,QSA]

# エラーページ（404）
ErrorDocument 404 /404.php
